const Reaction = ({ onScoreSubmitted }) => {
  const { user } = useAuth();
  const [state, setState] = useState(\"idle\"); // idle | waiting | ready | done | tooEarly
  const [ms, setMs] = useState(null);
  const [best, setBest] = useState(null);
  const timerRef = useRef(null);
  const startedAt = useRef(0);
  const { submit, submitting } = useScoreSubmit(\"reaction\", onScoreSubmitted);

  const begin = () => {
    setMs(null);
    setState(\"waiting\");
    const wait = 1200 + Math.random() * 2200;
    timerRef.current = setTimeout(() => {
      startedAt.current = performance.now();
      setState(\"ready\");
    }, wait);
  };

  const click = () => {
    if (state === \"idle\" || state === \"done\" || state === \"tooEarly\") {
      begin();
    } else if (state === \"waiting\") {
      clearTimeout(timerRef.current);
      setState(\"tooEarly\");
    } else if (state === \"ready\") {
      const took = Math.round(performance.now() - startedAt.current);
      setMs(took);
      setBest((b) => (b === null ? took : Math.min(b, took)));
      setState(\"done\");
    }
  };

  const bg =
    state === \"waiting\"
      ? \"bg-[#FEE715] text-black\"
      : state === \"ready\"
      ? \"bg-[#00FF41] text-black\"
      : state === \"tooEarly\"
      ? \"bg-red-500 text-black\"
      : \"bg-[#0C0C0E] text-white border border-[#1F2937]\";

  const label =
    state === \"idle\"
      ? \"Click to start\"
      : state === \"waiting\"
      ? \"Wait for GREEN…\"
      : state === \"ready\"
      ? \"CLICK NOW!\"
      : state === \"tooEarly\"
      ? \"Too early. Click to retry.\"
      : `${ms} ms · click for another`;

  return (
