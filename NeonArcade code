    password: str


class UserOut(BaseModel):
    id: str
    name: str
    email: EmailStr
    avatar: Optional[str] = None
    role: str = \"user\"
    created_at: str


class ScoreIn(BaseModel):
    game_id: str
    score: int = Field(ge=0)
    duration_sec: Optional[float] = None


class ScoreOut(BaseModel):
    id: str
    user_id: str
    user_name: str
    game_id: str
    score: int
    duration_sec: Optional[float] = None
    created_at: str


class ChatIn(BaseModel):
    game_id: Optional[str] = None
    session_id: Optional[str] = None
    message: str = Field(min_length=1, max_length=2000)


class ChatOut(BaseModel):
    session_id: str
    reply: str


# ---------- Games metadata ----------
GAMES = [
    {\"id\": \"tic-tac-toe\", \"name\": \"Tic Tac Toe\", \"tagline\": \"Outsmart the grid\", \"score_label\": \"Wins\"},
    {\"id\": \"snake\", \"name\": \"Neon Snake\", \"tagline\": \"Devour the dots\", \"score_label\": \"Length\"},
    {\"id\": \"memory\", \"name\": \"Memory Matrix\", \"tagline\": \"Match the pairs\", \"score_label\": \"Points\"},
    {\"id\": \"2048\", \"name\": \"2048\", \"tagline\": \"Merge to victory\", \"score_label\": \"Tile Score\"},
    {\"id\": \"rps\", \"name\": \"Rock Paper Scissors\", \"tagline\": \"Best the AI\", \"score_label\": \"Win Streak\"},
    {\"id\": \"reaction\", \"name\": \"Reaction Time\", \"tagline\": \"Lightning reflexes\", \"score_label\": \"ms (lower = better)\"},
]
GAME_IDS = {g[\"id\"] for g in GAMES}


# ---------- App ----------
app = FastAPI()
api = APIRouter(prefix=\"/api\")


# ---------- Auth Endpoints ----------
@api.post(\"/auth/register\", response_model=UserOut)
async def register(body: RegisterIn, response: Response):
    email = body.email.lower().strip()
    existing = await db.users.find_one({\"email\": email})
    if existing:
        raise HTTPException(status_code=400, detail=\"Email already registered\")
    user_id = str(uuid.uuid4())
    now = datetime.now(timezone.utc).isoformat()
    doc = {
        \"id\": user_id,
        \"name\": body.name.strip(),
        \"email\": email,
        \"password_hash\": hash_password(body.password),
        \"role\": \"user\",
        \"avatar\": None,
        \"created_at\": now,
    }
    await db.users.insert_one(doc)
    access = create_access_token(user_id, email)
    refresh = create_refresh_token(user_id)
    set_auth_cookies(response, access, refresh)
    return UserOut(id=user_id, name=doc[\"name\"], email=email, role=\"user\", avatar=None, created_at=now)


@api.post(\"/auth/login\", response_model=UserOut)
async def login(body: LoginIn, response: Response):
    email = body.email.lower().strip()
    user = await db.users.find_one({\"email\": email})
    if not user or not verify_password(body.password, user[\"password_hash\"]):
        raise HTTPException(status_code=401, detail=\"Invalid email or password\")
    access = create_access_token(user[\"id\"], email)
    refresh = create_refresh_token(user[\"id\"])
    set_auth_cookies(response, access, refresh)
    return UserOut(
        id=user[\"id\"], name=user[\"name\"], email=user[\"email\"],
        avatar=user.get(\"avatar\"), role=user.get(\"role\", \"user\"),
        created_at=user[\"created_at\"],
    )


@api.post(\"/auth/logout\")
async def logout(response: Response, _user: dict = Depends(get_current_user)):
    clear_auth_cookies(response)
    return {\"ok\": True}


@api.get(\"/auth/me\", response_model=UserOut)
async def me(user: dict = Depends(get_current_user)):
    return UserOut(**{k: user.get(k) for k in [\"id\", \"name\", \"email\", \"avatar\", \"role\", \"created_at\"]})


@api.post(\"/auth/refresh\")
async def refresh_token(request: Request, response: Response):
    token = request.cookies.get(\"refresh_token\")
    if not token:
        raise HTTPException(status_code=401, detail=\"No refresh token\")
    try:
        payload = jwt.decode(token, get_jwt_secret(), algorithms=[JWT_ALGORITHM])
        if payload.get(\"type\") != \"refresh\":
            raise HTTPException(status_code=401, detail=\"Invalid token type\")
        user = await db.users.find_one({\"id\": payload[\"sub\"]})
        if not user:
            raise HTTPException(status_code=401, detail=\"User not found\")
        access = create_access_token(user[\"id\"], user[\"email\"])
        response.set_cookie(\"access_token\", access, httponly=True, secure=True,
                            samesite=\"none\", max_age=60 * 60 * 24, path=\"/\")
        return {\"ok\": True}
    except jwt.InvalidTokenError:
        raise HTTPException(status_code=401, detail=\"Invalid refresh token\")


# ---------- Games / Scores ----------
@api.get(\"/games\")
async def list_games():
    return GAMES


def _better(game_id: str, a: int, b: int) -> bool:
    # For reaction time, lower is better
    if game_id == \"reaction\":
        return a < b
    return a > b


@api.post(\"/scores\", response_model=ScoreOut)
async def submit_score(body: ScoreIn, user: dict = Depends(get_current_user)):
    if body.game_id not in GAME_IDS:
        raise HTTPException(status_code=400, detail=\"Unknown game\")
    score_id = str(uuid.uuid4())
    now = datetime.now(timezone.utc).isoformat()
    doc = {
        \"id\": score_id,
        \"user_id\": user[\"id\"],
        \"user_name\": user[\"name\"],
        \"game_id\": body.game_id,
        \"score\": int(body.score),
        \"duration_sec\": body.duration_sec,
        \"created_at\": now,
    }
    await db.scores.insert_one(doc)

    # Update personal best
    pb = await db.personal_bests.find_one({\"user_id\": user[\"id\"], \"game_id\": body.game_id})
    if pb is None or _better(body.game_id, body.score, pb[\"score\"]):
        await db.personal_bests.update_one(
            {\"user_id\": user[\"id\"], \"game_id\": body.game_id},
            {\"$set\": {
                \"user_id\": user[\"id\"], \"user_name\": user[\"name\"],
                \"game_id\": body.game_id, \"score\": body.score, \"updated_at\": now,
            }},
            upsert=True,
        )
    return ScoreOut(**{k: doc[k] for k in [\"id\", \"user_id\", \"user_name\", \"game_id\", \"score\", \"duration_sec\", \"created_at\"]})


@api.get(\"/leaderboard/{game_id}\")
async def leaderboard(game_id: str, limit: int = 20):
    if game_id not in GAME_IDS:
        raise HTTPException(status_code=404, detail=\"Unknown game\")
    sort_dir = 1 if game_id == \"reaction\" else -1
    rows = await db.personal_bests.find(
        {\"game_id\": game_id}, {\"_id\": 0}
    ).sort(\"score\", sort_dir).limit(limit).to_list(limit)
    return rows


@api.get(\"/me/scores\")
async def my_scores(user: dict = Depends(get_current_user)):
    rows = await db.scores.find(
        {\"user_id\": user[\"id\"]}, {\"_id\": 0}
    ).sort(\"created_at\", -1).limit(50).to_list(50)
    bests = await db.personal_bests.find(
        {\"user_id\": user[\"id\"]}, {\"_id\": 0}
    ).to_list(100)
    return {\"recent\": rows, \"personal_bests\": bests}


# ---------- AI Assistant ----------
def _system_prompt(game_id: Optional[str]) -> str:
    base = (
        \"You are NEON, the in-house AI assistant for the Neon Arcade gaming hub. \"
        \"You give punchy, friendly tips, strategy hints and trivia for classic browser mini-games \"
        \"(Tic Tac Toe, Snake, Memory Matrix, 2048, Rock Paper Scissors, Reaction Time). \"
        \"Keep replies short (max 5 sentences), upbeat, and never reveal you are an AI model brand. \"
        \"Use light cyberpunk vibe in tone.\"
    )
    if game_id:
        base += f\" The user is currently playing: {game_id}.\"
    return base


@api.post(\"/ai/chat\", response_model=ChatOut)
async def ai_chat(body: ChatIn, user: dict = Depends(get_current_user)):
    api_key = os.environ.get(\"EMERGENT_LLM_KEY\")
    if not api_key:
        raise HTTPException(status_code=500, detail=\"AI not configured\")
    session_id = body.session_id or f\"{user['id']}:{body.game_id or 'general'}\"
    try:
        chat = LlmChat(
            api_key=api_key,
            session_id=session_id,
            system_message=_system_prompt(body.game_id),
        ).with_model(\"anthropic\", \"claude-sonnet-4-5-20250929\")
        msg = UserMessage(text=body.message)
        reply = await chat.send_message(msg)

        await db.chat_messages.insert_one({
            \"id\": str(uuid.uuid4()),
            \"user_id\": user[\"id\"],
            \"session_id\": session_id,
            \"game_id\": body.game_id,
            \"user_message\": body.message,
            \"assistant_reply\": reply,
            \"created_at\": datetime.now(timezone.utc).isoformat(),
        })
        return ChatOut(session_id=session_id, reply=str(reply))
    except Exception as e:
        logger.exception(\"AI chat failed\")
        raise HTTPException(status_code=500, detail=f\"AI error: {e}\")


