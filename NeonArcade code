                  className={`max-w-[85%] px-3 py-2 ${
                    m.role === \"user\"
                      ? \"bg-[#00F0FF]/10 border border-[#00F0FF]/40 text-white\"
                      : \"bg-[#151518] border border-[#1F2937] text-zinc-200\"
