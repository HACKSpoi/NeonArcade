import { useScoreSubmit } from \"./_scoreUtils\";
import { useAuth } from \"../contexts/AuthContext\";

const SIZE = 4;
const empty = () => Array(SIZE * SIZE).fill(0);

const addTile = (grid) => {
  const empties = grid.map((v, i) => (v === 0 ? i : -1)).filter((i) => i >= 0);
  if (empties.length === 0) return grid;
  const i = empties[Math.floor(Math.random() * empties.length)];
  const g = [...grid];
  g[i] = Math.random() < 0.9 ? 2 : 4;
  return g;
};

const rotate = (grid) => {
  // rotate 90° clockwise
  const n = Array(SIZE * SIZE).fill(0);
  for (let r = 0; r < SIZE; r++) for (let c = 0; c < SIZE; c++) n[c * SIZE + (SIZE - 1 - r)] = grid[r * SIZE + c];
  return n;
};

const slideRow = (row) => {
  const filtered = row.filter((v) => v !== 0);
  const out = [];
  let gained = 0;
  let i = 0;
  while (i < filtered.length) {
    if (filtered[i] === filtered[i + 1]) {
      out.push(filtered[i] * 2);
      gained += filtered[i] * 2;
      i += 2;
    } else {
      out.push(filtered[i]);
      i += 1;
    }
  }
  while (out.length < SIZE) out.push(0);
  return { row: out, gained };
};

const moveLeft = (grid) => {
  let gained = 0;
  const next = [];
  for (let r = 0; r < SIZE; r++) {
    const { row, gained: g } = slideRow(grid.slice(r * SIZE, r * SIZE + SIZE));
    gained += g;
    next.push(...row);
  }
  return { grid: next, gained, changed: next.some((v, i) => v !== grid[i]) };
};

const move = (grid, dir) => {
  // dir: 0=left, 1=up, 2=right, 3=down. Use rotation strategy.
  let g = grid;
  for (let i = 0; i < dir; i++) g = rotate(g);
  const res = moveLeft(g);
  let n = res.grid;
  for (let i = 0; i < (4 - dir) % 4; i++) n = rotate(n);
  return { grid: n, gained: res.gained, changed: res.changed };
};

const canMove = (g) => {
  if (g.some((v) => v === 0)) return true;
  for (let r = 0; r < SIZE; r++)
    for (let c = 0; c < SIZE; c++) {
      const v = g[r * SIZE + c];
      if (c + 1 < SIZE && g[r * SIZE + c + 1] === v) return true;
      if (r + 1 < SIZE && g[(r + 1) * SIZE + c] === v) return true;
    }
  return false;
};

const COLORS = {
  0: \"bg-[#0C0C0E] text-transparent\",
  2: \"bg-[#15202B] text-zinc-300\",
  4: \"bg-[#1E2D3D] text-zinc-200\",
  8: \"bg-[#22484F] text-[#00F0FF]\",
  16: \"bg-[#005f6b] text-white\",
  32: \"bg-[#00808a] text-white\",
  64: \"bg-[#00aaba] text-black\",
  128: \"bg-[#FEE715] text-black\",
  256: \"bg-[#FFCD15] text-black\",
  512: \"bg-[#FFA700] text-black\",
  1024: \"bg-[#FF7700] text-black\",
  2048: \"bg-[#00FF41] text-black\",
};

const Game2048 = ({ onScoreSubmitted }) => {
  const { user } = useAuth();
  const [grid, setGrid] = useState(() => addTile(addTile(empty())));
  const [score, setScore] = useState(0);
  const [dead, setDead] = useState(false);
  const stateRef = useRef({ grid, score, dead });
  stateRef.current = { grid, score, dead };
  const { submit, submitting } = useScoreSubmit(\"2048\", onScoreSubmitted);

  const reset = () => {
    setGrid(addTile(addTile(empty())));
    setScore(0);
    setDead(false);
  };

  useEffect(() => {
    const onKey = (e) => {
      const map = { ArrowLeft: 0, ArrowUp: 1, ArrowRight: 2, ArrowDown: 3, a: 0, w: 1, d: 2, s: 3 };
      const dir = map[e.key];
      if (dir === undefined || stateRef.current.dead) return;
      e.preventDefault();
      const { grid: ng, gained, changed } = move(stateRef.current.grid, dir);
      if (!changed) return;
      const withTile = addTile(ng);
      setGrid(withTile);
      setScore((s) => s + gained);
      if (!canMove(withTile)) setDead(true);
    };
    window.addEventListener(\"keydown\", onKey);
    return () => window.removeEventListener(\"keydown\", onKey);
  }, []);

  return (
    <div className=\"space-y-4\">
      <div className=\"flex justify-between text-sm\">
        <div>Arrows / WASD</div>
        <div>Score: <span data-testid=\"g2048-score\" className=\"text-[#FEE715] font-mono\">{score}</span></div>
      </div>

      <div className=\"grid grid-cols-4 gap-2 max-w-[420px] mx-auto card-neon p-2\" data-testid=\"g2048-board\">
        {grid.map((v, i) => (
          <div
            key={i}
            className={`aspect-square flex items-center justify-center font-heading font-black text-2xl ${COLORS[v] || \"bg-[#FF4444] text-black\"}`}
          >
            {v || \"\"}
          </div>
        ))}
      </div>

      <div className=\"flex justify-center gap-3\">
        <button data-testid=\"g2048-reset\" onClick={reset} className=\"btn-outline-cyan\">New Game</button>
        {(dead || score > 0) && user && user !== false && (
          <button data-testid=\"g2048-submit\" onClick={() => submit(score)} disabled={submitting} className=\"btn-primary\">
            Submit {score}
          </button>
        )}
      </div>

      {dead && <div className=\"text-center text-red-400 font-heading text-xl\" data-testid=\"g2048-dead\">GAME OVER</div>}
    </div>
  );
};

