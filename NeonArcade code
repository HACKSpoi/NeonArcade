export const submitScore = async (game_id, score, duration_sec = null) => {
  try {
    await api.post(\"/scores\", { game_id, score, duration_sec });
    toast.success(`Score submitted: ${score}`);
    return true;
  } catch (e) {
    if (e.response?.status === 401) {
      toast.error(\"Login to submit scores.\");
    } else {
      toast.error(\"Could not submit score.\");
    }
    return false;
  }
};

export const useScoreSubmit = (gameId, onScoreSubmitted) => {
  const [submitting, setSubmitting] = useState(false);
  const submit = async (score, duration_sec = null) => {
    setSubmitting(true);
    const ok = await submitScore(gameId, score, duration_sec);
    setSubmitting(false);
    if (ok && onScoreSubmitted) onScoreSubmitted();
    return ok;
  };
  return { submit, submitting };
};
