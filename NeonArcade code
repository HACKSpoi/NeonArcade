import { useScoreSubmit } from \"./_scoreUtils\";
import { useAuth } from \"../contexts/AuthContext\";

const LINES = [
  [0, 1, 2], [3, 4, 5], [6, 7, 8],
  [0, 3, 6], [1, 4, 7], [2, 5, 8],
  [0, 4, 8], [2, 4, 6],
];

const winnerOf = (b) => {
  for (const [a, c, d] of LINES) if (b[a] && b[a] === b[c] && b[a] === b[d]) return { player: b[a], line: [a, c, d] };
  if (b.every(Boolean)) return { player: \"draw\" };
  return null;
};

const aiMove = (board) => {
  // Try win, then block, else center, else random
  const tryWin = (mark) => {
    for (let i = 0; i < 9; i++) {
      if (!board[i]) {
        const b = [...board];
        b[i] = mark;
        if (winnerOf(b)?.player === mark) return i;
      }
    }
    return -1;
  };
  let m = tryWin(\"O\");
  if (m >= 0) return m;
  m = tryWin(\"X\");
  if (m >= 0) return m;
  if (!board[4]) return 4;
  const empty = board.map((v, i) => (v ? -1 : i)).filter((v) => v >= 0);
  return empty[Math.floor(Math.random() * empty.length)];
};

const TicTacToe = ({ onScoreSubmitted }) => {
  const { user } = useAuth();
  const [board, setBoard] = useState(Array(9).fill(null));
  const [turn, setTurn] = useState(\"X\");
  const [wins, setWins] = useState(0);
  const [result, setResult] = useState(null);
  const { submit, submitting } = useScoreSubmit(\"tic-tac-toe\", onScoreSubmitted);

  const w = winnerOf(board);

  useEffect(() => {
    if (!w && turn === \"O\") {
      const t = setTimeout(() => {
        setBoard((b) => {
          const nb = [...b];
          const m = aiMove(nb);
          if (m >= 0) nb[m] = \"O\";
          return nb;
        });
        setTurn(\"X\");
      }, 380);
      return () => clearTimeout(t);
    }
    if (w && !result) {
      setResult(w);
      if (w.player === \"X\") setWins((x) => x + 1);
    }
  }, [board, turn, w, result]);

  const click = (i) => {
    if (board[i] || w || turn !== \"X\") return;
    const nb = [...board];
    nb[i] = \"X\";
    setBoard(nb);
    setTurn(\"O\");
  };

  const reset = () => {
    setBoard(Array(9).fill(null));
    setTurn(\"X\");
    setResult(null);
  };

  return (
    <div className=\"space-y-6\">
      <div className=\"flex items-center justify-between text-sm\">
        <div>You: <span className=\"neon-text-cyan font-bold\">X</span> · AI: <span className=\"neon-text-yellow font-bold\">O</span></div>
        <div data-testid=\"ttt-wins\">Wins: <span className=\"text-[#00FF41] font-mono\">{wins}</span></div>
      </div>

      <div className=\"grid grid-cols-3 gap-2 max-w-[420px] mx-auto\">
        {board.map((cell, i) => (
          <button
            key={i}
            data-testid={`ttt-cell-${i}`}
            onClick={() => click(i)}
            className={`aspect-square card-neon flex items-center justify-center text-5xl font-heading font-black ${
              w?.line?.includes(i) ? \"border-[#00FF41] text-[#00FF41] glow-green\" : \"\"
            } ${cell === \"X\" ? \"text-[#00F0FF]\" : cell === \"O\" ? \"text-[#FEE715]\" : \"\"}`}
          >
            {cell}
          </button>
        ))}
      </div>

      <div className=\"text-center\">
        {result && (
          <div data-testid=\"ttt-result\" className=\"mb-4 font-heading text-xl\">
            {result.player === \"draw\"
              ? \"DRAW.\"
              : result.player === \"X\"
              ? \"VICTORY.\"
              : \"DEFEATED.\"}
          </div>
        )}
        <div className=\"flex justify-center gap-3\">
          <button data-testid=\"ttt-reset\" onClick={reset} className=\"btn-outline-cyan\">New Round</button>
          {user && user !== false && wins > 0 && (
            <button
              data-testid=\"ttt-submit\"
              onClick={() => submit(wins)}
              disabled={submitting}
              className=\"btn-primary\"
            >
              Submit {wins} Win{wins === 1 ? \"\" : \"s\"}
            </button>
          )}
        </div>
      </div>
    </div>
  );
};

